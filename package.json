{
  "name": "ableton-backup",
  "version": "1.0.0",
  "description": "Backups for Ableton without affecting performance",
  "main": "dist/cli.js",
  "bin": {
    "ableton-backup": "bin/ableton-backup"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "test": "jest",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carlosesilva/ableton-backup.git"
  },
  "keywords": [
    "ableton",
    "backup",
    "macos",
    "music"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=14.0.0"
  },
  "bugs": {
    "url": "https://github.com/carlosesilva/ableton-backup/issues"
  },
  "homepage": "https://github.com/carlosesilva/ableton-backup#readme",
  "dependencies": {
    "archiver": "^7.0.1",
    "commander": "^14.0.3",
    "inquirer": "^13.3.0",
    "js-yaml": "^4.1.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.5",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ]
  }
}
